# Set default values for all accounts.
defaults
auth           off
tls            off
tls_starttls   off
logfile        /var/www/html/logs/msmtp.log

# MailHog service (host name comes from docker-compose)
account        mailhog
host           mailhog
port           1025

# Set mailhog as the default account to use.
account default : mailhog