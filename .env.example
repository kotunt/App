# Application Environment: 'development', 'staging', or 'production'
APP_ENV=development

# -- Database Credentials (for PHP service) --
# These are used by your PHP application to connect to the database container.
DB_DRIVER=mysql
DB_HOST=db
DB_NAME=thai_2d3d_db
DB_USER=root
DB_PASS=secret

# -- MySQL Service Configuration --
# These are used by the 'db' service itself to initialize the database.
# The values should match the PHP credentials above.
MYSQL_DATABASE=thai_2d3d_db
MYSQL_USER=root
MYSQL_PASSWORD=secret
MYSQL_ROOT_PASSWORD=secret

# -- Redis Configuration --
REDIS_HOST=redis
REDIS_PORT=6379