# Example environment file for local development
# Copy this to .env and fill in real values. Do NOT commit .env to version control.

# For Docker setup, use the service name 'db'. For local XAMPP/WAMP, use 'localhost'.
DB_HOST=db
DB_NAME=thai_2d3d_db
DB_USER=root
DB_PASS=supersecret
DB_ROOT_PASSWORD=supersecret # For docker-compose MySQL root user

# Database driver: 'mysql' or 'sqlite'
DB_DRIVER=mysql

# Application environment: development, staging, production
APP_ENV=development
